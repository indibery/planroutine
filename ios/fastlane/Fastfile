default_platform(:ios)

# ── 공통 헬퍼 ──
# 함정 #6 회피: 통합 테스트(시뮬 빌드)가 남긴 native_assets 시뮬 슬라이스가
# 디바이스 IPA에 묶이면 altool 91169("Simulator platforms aren't permitted")로
# 거부된다. flutter clean + Pods/build 제거로 캐시를 비우고, 이어지는
# `flutter build ipa`가 pub get + pod install을 재수행해 클린 재구성한다.
# (바로팀과 달리 공직플랜은 flutter build ipa가 pod install을 직접 처리하므로
#  명시적 pod install·GEM unset(#7)은 불필요.)
def reset_ios_caches
  UI.header("iOS 캐시 정리 — 시뮬 슬라이스 방지 (함정 #6)")
  # __dir__ = ios/fastlane → 두 단계 위가 프로젝트 루트.
  project_root = File.expand_path("../..", __dir__)
  Dir.chdir(project_root) do
    sh("flutter", "clean")
    sh("rm", "-rf", "ios/Pods", "ios/Podfile.lock", "ios/build")
  end
end

# pubspec.yaml의 versionString(X.Y.Z) 파싱. 빌드 이름은 이 값을 그대로 쓴다
# (레인이 --build-name을 안 넘기므로 flutter가 pubspec 버전을 사용).
def pubspec_version_name
  project_root = File.expand_path("../..", __dir__)
  pubspec = File.read(File.join(project_root, "pubspec.yaml"))
  match = pubspec.match(/^version:\s*(\d+\.\d+\.\d+)/)
  UI.user_error!("pubspec.yaml에서 version을 찾을 수 없습니다") unless match
  match[1]
end

def next_patch(version)
  parts = version.split(".").map(&:to_i)
  parts[2] = (parts[2] || 0) + 1
  parts.join(".")
end

# 함정 #5 선제 차단: pubspec versionString이 App Store 승인본(현재 판매 중 버전)
# 이하이면 그 train이 닫혀 있어 altool이 업로드를 거부한다(90062/90186).
# clean 빌드(수 분) + 업로드까지 다 돌린 뒤 거부당하는 낭비를 막으려고,
# 빌드 전에 즉시 NO-GO로 중단한다. 버전 자동 증가는 하지 않는다 — 증가폭은 사람 판단.
def assert_version_bumped(api_key)
  require 'spaceship'
  Spaceship::ConnectAPI.token = Spaceship::ConnectAPI::Token.from(hash: api_key)
  app = Spaceship::ConnectAPI::App.find("com.planroutine.app")
  live = app&.get_live_app_store_version
  local = pubspec_version_name

  # 승인본이 아직 없으면(최초 출시 전) 가드 통과.
  if live.nil?
    UI.message("App Store 승인본 없음 — 버전 가드 통과 (pubspec #{local})")
    return
  end

  approved = live.version_string
  if Gem::Version.new(local) > Gem::Version.new(approved)
    UI.success("버전 가드 통과: pubspec #{local} > 승인본 #{approved}")
  else
    UI.user_error!(
      "pubspec 버전 #{local}이(가) App Store 승인본 #{approved} 이하입니다. " \
      "이 train은 닫혀 있어 업로드가 거부됩니다(함정 #5). " \
      "빌드 전 중단 — pubspec.yaml의 version을 올리세요 (예: #{next_patch(approved)})."
    )
  end
end

platform :ios do

  # ── App Store Connect API Key 인증 ──
  desc "App Store Connect API Key 로드"
  lane :load_asc_api_key do
    app_store_connect_api_key(
      key_id: "D8W86CLKHY",
      issuer_id: "69a6de72-97eb-47e3-e053-5b8c7c11a4d1",
      key_filepath: File.expand_path("~/.appstoreconnect/private_keys/AuthKey_D8W86CLKHY.p8"),
    )
  end

  # ── TestFlight 배포 ──
  desc "TestFlight에 새 빌드 업로드"
  lane :beta do
    api_key = load_asc_api_key

    # 함정 #5 선제 차단: 승인본 이하 버전이면 clean 빌드 전에 중단
    assert_version_bumped(api_key)

    # 빌드 번호 자동 증가 (TestFlight 최신 빌드 + 1)
    latest = latest_testflight_build_number(
      app_identifier: "com.planroutine.app",
    )
    new_build_number = latest + 1
    UI.message("빌드 번호: #{latest} → #{new_build_number}")

    reset_ios_caches

    # Flutter 빌드
    Dir.chdir("..") do
      sh("flutter", "build", "ipa",
        "--release",
        "--build-number=#{new_build_number}",
      )
    end

    # IPA 파일명이 한글(공직플랜.ipa)이라 Ruby Dir[] glob이 매치 못함. Dir.entries로
    # 직접 순회해 찾는다. 파일명이 또 바뀌어도 깨지지 않는다.
    # __dir__ = ios/fastlane → 두 단계 올라가 프로젝트 루트.
    project_root = File.expand_path("../..", __dir__)
    ipa_dir = File.join(project_root, "build/ios/ipa")
    ipa_name = Dir.entries(ipa_dir).find { |f| f.end_with?(".ipa") }
    UI.user_error!("빌드된 IPA를 찾을 수 없습니다 (#{ipa_dir})") unless ipa_name
    ipa_path = File.join(ipa_dir, ipa_name)

    upload_to_testflight(
      ipa: ipa_path,
      skip_waiting_for_build_processing: true,
    )

    UI.success("TestFlight 배포 완료! v#{new_build_number}")
  end

  # ── App Store 배포 ──
  desc "App Store에 새 버전 제출"
  lane :release do
    api_key = load_asc_api_key

    # 함정 #5 선제 차단: 승인본 이하 버전이면 clean 빌드 전에 중단
    assert_version_bumped(api_key)

    latest = latest_testflight_build_number(
      app_identifier: "com.planroutine.app",
    )
    new_build_number = latest + 1

    reset_ios_caches

    Dir.chdir("..") do
      sh("flutter", "build", "ipa",
        "--release",
        "--build-number=#{new_build_number}",
      )
    end

    # __dir__ = ios/fastlane → 두 단계 올라가 프로젝트 루트.
    project_root = File.expand_path("../..", __dir__)
    ipa_dir = File.join(project_root, "build/ios/ipa")
    ipa_name = Dir.entries(ipa_dir).find { |f| f.end_with?(".ipa") }
    UI.user_error!("빌드된 IPA를 찾을 수 없습니다 (#{ipa_dir})") unless ipa_name
    ipa_path = File.join(ipa_dir, ipa_name)

    upload_to_app_store(
      ipa: ipa_path,
      skip_metadata: true,
      skip_screenshots: true,
      submit_for_review: false,
      # 바이너리 업로드만 하고 심사 제출은 App Store Connect에서 수동. precheck는
      # 심사 전 검증이라 불필요하고, ASC API Key로는 IAP 확인이 안 돼 에러가 난다.
      run_precheck_before_submit: false,
    )

    UI.success("App Store 업로드 완료! v#{new_build_number}")
  end

  # ── post-deploy: TestFlight 빌드 처리 상태 조회 ──
  desc "TestFlight 빌드 상태 조회 (processing_state 확인)"
  lane :check_builds do
    api_key = load_asc_api_key
    require 'spaceship'
    Spaceship::ConnectAPI.token = Spaceship::ConnectAPI::Token.from(hash: api_key)
    app = Spaceship::ConnectAPI::App.find("com.planroutine.app")
    UI.message("App ID: #{app.id}")
    builds = Spaceship::ConnectAPI::Build.all(app_id: app.id, limit: 5, sort: "-uploadedDate")
    builds.each do |b|
      UI.message("  v#{b.version} (#{b.processing_state}) — uploaded #{b.uploaded_date}")
    end
  end

end
